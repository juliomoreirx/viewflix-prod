{
  "info": {
    "name": "Viewflix Admin API",
    "_postman_id": "7b6f2f13-a8a8-4f5f-a4af-2d9adbe8f9e7",
    "description": "Coleção para endpoints administrativos do Viewflix.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin - Stats",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/stats",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "stats"
          ]
        },
        "description": "Resumo geral de usuários, compras, conteúdo e catálogo."
      }
    },
    {
      "name": "Admin - Users (default)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users"
          ]
        },
        "description": "Lista usuários com paginação padrão."
      }
    },
    {
      "name": "Admin - Users (com filtros)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users?page=1&limit=50&q=joao&sortBy=lastAccess&sortOrder=desc&includePurchases=true&purchasesLimit=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "50"
            },
            {
              "key": "q",
              "value": "joao"
            },
            {
              "key": "sortBy",
              "value": "lastAccess"
            },
            {
              "key": "sortOrder",
              "value": "desc"
            },
            {
              "key": "includePurchases",
              "value": "true"
            },
            {
              "key": "purchasesLimit",
              "value": "5"
            }
          ]
        },
        "description": "Filtra por termo, ordena por último acesso e traz compras recentes por usuário."
      }
    },
    {
      "name": "Admin - Users (apenas bloqueados)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users?blocked=true&page=1&limit=100",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "blocked",
              "value": "true"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "100"
            }
          ]
        },
        "description": "Lista somente usuários bloqueados."
      }
    },
    {
      "name": "Admin - Refresh Cache",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/refresh-cache",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "refresh-cache"
          ]
        },
        "description": "Força atualização do cache de catálogo."
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://watch.viewflix.space"
    },
    {
      "key": "adminToken",
      "value": "SEU_ADMIN_API_TOKEN"
    }
  ]
}
